

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  {{ section.shopify_attributes }}
>
  <div
    class="utilities utilities--blocks-{{ section.blocks.size }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %} --border-width: {{ section.settings.divider_thickness }}px;{% if section.settings.divider_color != blank %} --divider-color: {{ section.settings.divider_color }};{% endif %} --gap: {{ section.settings.gap }}px;"
    data-testid="footer-utilities"
  >
    {% content_for 'blocks' %}
  </div>

  {%- comment -%} Luna Clara payment badges — fixed visual row to match lunaclaradesigns.com {%- endcomment -%}
  <div class="lc-payments" aria-label="Accepted payment methods">
    <span class="lc-payment-badge" title="Visa" role="img" aria-label="Visa">
      <svg viewBox="0 0 48 16" aria-hidden="true">
        <text x="0" y="13" font-family="Arial, Helvetica, sans-serif" font-size="15" font-style="italic" font-weight="700" fill="#1A1F71" letter-spacing="0.5">VISA</text>
      </svg>
    </span>
    <span class="lc-payment-badge" title="Mastercard" role="img" aria-label="Mastercard">
      <svg viewBox="0 0 36 22" aria-hidden="true">
        <circle cx="14" cy="11" r="9" fill="#EB001B"></circle>
        <circle cx="22" cy="11" r="9" fill="#F79E1B"></circle>
        <path d="M18 4.2a9 9 0 0 1 0 13.6 9 9 0 0 1 0-13.6Z" fill="#FF5F00"></path>
      </svg>
    </span>
    <span class="lc-payment-badge" title="American Express" role="img" aria-label="American Express">
      <svg viewBox="0 0 44 16" aria-hidden="true">
        <rect width="44" height="16" rx="2" fill="#1F72CD"></rect>
        <text x="22" y="11.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="7.5" font-weight="700" fill="#FFFFFF" letter-spacing="0.3">AMEX</text>
      </svg>
    </span>
    <span class="lc-payment-badge" title="PayPal" role="img" aria-label="PayPal">
      <svg viewBox="0 0 52 16" aria-hidden="true">
        <text x="0" y="13" font-family="Arial, Helvetica, sans-serif" font-size="14" font-style="italic" font-weight="700" fill="#003087">Pay</text>
        <text x="25" y="13" font-family="Arial, Helvetica, sans-serif" font-size="14" font-style="italic" font-weight="700" fill="#009CDE">Pal</text>
      </svg>
    </span>
    <span class="lc-payment-badge" title="Apple Pay" role="img" aria-label="Apple Pay">
      <svg viewBox="0 0 44 18" aria-hidden="true">
        <path d="M8.04 4.6c-.5.6-1.3 1.05-2.1.98-.1-.8.3-1.66.76-2.2.5-.6 1.36-1.04 2.06-1.06.08.84-.25 1.66-.72 2.28Zm.71 1.13c-1.16-.07-2.15.66-2.7.66-.56 0-1.4-.62-2.32-.6-1.2.01-2.3.69-2.9 1.76-1.24 2.15-.32 5.33.89 7.08.59.86 1.3 1.82 2.22 1.79.88-.04 1.22-.57 2.29-.57 1.06 0 1.37.57 2.3.55.96-.02 1.56-.87 2.15-1.74.68-1 .95-1.96.97-2.01-.02-.01-1.86-.72-1.88-2.84-.02-1.78 1.45-2.63 1.52-2.67-.83-1.23-2.12-1.37-2.58-1.4Z" fill="#000000"></path>
        <text x="15" y="13.5" font-family="Arial, Helvetica, sans-serif" font-size="11" font-weight="600" fill="#000000">Pay</text>
      </svg>
