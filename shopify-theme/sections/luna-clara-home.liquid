{% liquid
  assign featured_collection = section.settings.featured_collection
  if featured_collection == blank
    assign featured_collection = collections.all
  endif
%}

<section class="lc-home" data-lc-home>
  <div class="lc-hero">
    <div class="lc-hero__copy">
      <p class="lc-eyebrow">Premium Gem · Designed in USA</p>
      <h1>Luna Clara Designs</h1>
      <p class="lc-hero__tagline">Made to glow with you.</p>
      <p class="lc-hero__body">
        Curated jewelry and gift-ready pieces with a celestial finish, polished packaging,
        and just enough sparkle for the moments people remember.
      </p>
      <div class="lc-actions">
        <a href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}" class="lc-button">
          {{ section.settings.primary_label }}
        </a>
        <a href="{{ section.settings.secondary_link | default: routes.collections_url }}" class="lc-button lc-button--secondary">
          {{ section.settings.secondary_label }}
        </a>
      </div>
      <div class="lc-proof">
        <span><strong>Gift-ready</strong> Boxes, ribbon, and polish</span>
        <span><strong>Curated</strong> Selected for glow</span>
        <span><strong>Personal</strong> For every celebration</span>
      </div>
    </div>

    <div class="lc-hero__visual" data-lc-tilt>
      <img
        src="{{ 'luna-clara-spline-fallback.png' | asset_url }}"
        alt="Gold crescent moon, starburst, and jewelry pieces for Luna Clara Designs"
        loading="eager"
        width="1254"
        height="1254"
      >
      <span class="lc-orbit lc-orbit--one"></span>
      <span class="lc-orbit lc-orbit--two"></span>
      <span class="lc-orbit lc-orbit--three"></span>
    </div>
  </div>

  <div class="lc-marquee" aria-label="Gift occasions">
    <div>
      {% for i in (1..2) %}
        <span>Birthday</span><b>*</b>
        <span>Anniversary</span><b>*</b>
        <span>Eid</span><b>*</b>
        <span>Mother's Day</span><b>*</b>
        <span>Valentine's Day</span><b>*</b>
        <span>Weddings</span><b>*</b>
        <span>Bridesmaids</span><b>*</b>
        <span>Just Because</span><b>*</b>
      {% endfor %}
    </div>
  </div>

  <div class="lc-section lc-section--collections">
    <div class="lc-section__heading">
      <p class="lc-eyebrow">Shop the mood</p>
      <h2>Jewelry for the moment</h2>
      <p>Product-first, refined, and ready for gifting.</p>
    </div>
    <div class="lc-collection-grid">
      <a class="lc-collection-card" href="/collections/all">
        <img src="{{ 'earrings-pearl-starburst.jpg' | asset_url }}" alt="Starburst earrings">
        <span>The Jewelry Edit</span>
        <small>Delicate earrings, necklaces, bracelets, and rings.</small>
      </a>
      <a class="lc-collection-card" href="/collections/all">
        <img src="{{ 'luna-clara-jewelry-model.png' | asset_url }}" alt="Gift-ready Luna Clara jewelry styling">
        <span>Gift Box Moments</span>
        <small>Curated pieces with a ready-to-give finish.</small>
      </a>
      <a class="lc-collection-card" href="/collections/all">
        <img src="{{ 'luna-clara-spline-fallback.png' | asset_url }}" alt="Celestial Luna Clara jewelry scene">
        <span>Luxe Celebrations</span>
        <small>Elevated pieces for the occasions that matter.</small>
      </a>
    </div>
  </div>

  <div class="lc-section lc-section--products">
    <div class="lc-section__heading lc-section__heading--split">
      <div>
        <p class="lc-eyebrow">Handpicked for you</p>
        <h2>Glow Picks</h2>
      </div>
      <a href="{{ featured_collection.url | default: routes.all_products_collection_url }}">View all</a>
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0 %}
      <div class="lc-product-grid">
        {% for product in featured_collection.products limit: 4 %}
          <a class="lc-product-card" href="{{ product.url }}">
            <div class="lc-product-card__image">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
              {% else %}
                <div class="lc-product-card__placeholder">{{ product.title }}</div>
              {% endif %}
            </div>
            <span>{{ product.title }}</span>
            <small>{{ product.price | money }}</small>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="lc-empty-products">
        Import `shopify-products-import.csv` to populate this row with Luna Clara products.
      </div>
    {% endif %}
  </div>

  <div class="lc-story">
    <div class="lc-story__image" data-lc-focus>
      <img
        src="{{ 'luna-clara-jewelry-model.png' | asset_url }}"
        alt="Model wearing Luna Clara earring, necklace, bracelet, and ring"
        loading="lazy"
        width="1170"
        height="1420"
      >
      <span class="lc-focus-ring" aria-hidden="true"></span>
      <span class="lc-focus-label">Earring</span>
    </div>
    <div class="lc-story__copy">
      <p class="lc-eyebrow">Our Story</p>
      <h2>More Than Jewelry</h2>
      <p>
        Luna Clara is built around the full gesture: the piece, the packaging, the ribbon,
        and the feeling of opening something chosen with care.
      </p>
      <p>Move across the image to focus earring, necklace, bracelet, then ring.</p>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.currentScript.closest('.shopify-section')?.querySelector('[data-lc-home]');
    if (!root) return;

    root.querySelectorAll('[data-lc-tilt]').forEach((node) => {
      node.addEventListener('pointermove', (event) => {
        const rect = node.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width - 0.5;
        const y = (event.clientY - rect.top) / rect.height - 0.5;
        node.style.setProperty('--tilt-x', `${(-y * 6).toFixed(2)}deg`);
        node.style.setProperty('--tilt-y', `${(x * 8).toFixed(2)}deg`);
      });
      node.addEventListener('pointerleave', () => {
        node.style.setProperty('--tilt-x', '0deg');
        node.style.setProperty('--tilt-y', '0deg');
      });
    });

    const focus = root.querySelector('[data-lc-focus]');
    if (!focus) return;
    const points = [
      { label: 'Earring', x: 36, y: 28, origin: '34% 26%' },
      { label: 'Necklace', x: 44, y: 60, origin: '45% 58%' },
      { label: 'Bracelet', x: 86, y: 78, origin: '84% 78%' },
      { label: 'Ring', x: 62, y: 54, origin: '62% 54%' }
    ];
    const label = focus.querySelector('.lc-focus-label');
    const setPoint = (index) => {
      const point = points[index];
      focus.style.setProperty('--focus-x', `${point.x}%`);
      focus.style.setProperty('--focus-y', `${point.y}%`);
      focus.style.setProperty('--focus-origin', point.origin);
      label.textContent = point.label;
    };
    setPoint(0);
    focus.addEventListener('pointermove', (event) => {
      const rect = focus.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width;
      setPoint(Math.min(points.length - 1, Math.max(0, Math.floor(x * points.length))));
    });
  })();
</script>

{% stylesheet %}
  .lc-home {
    --lc-gold: #C9A84C;
    --lc-gold-light: #E8C97A;
    --lc-cream: #FDF8F2;
    --lc-champagne: #F7E7CE;
    --lc-blush: #F2B5C0;
    --lc-charcoal: #2C2C2C;
    --lc-gray: #8A8A8A;
    background: var(--lc-cream);
    color: var(--lc-charcoal);
    overflow: hidden;
  }

  .lc-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    align-items: center;
    gap: clamp(24px, 5vw, 72px);
    min-height: 76vh;
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(56px, 8vw, 96px) 24px;
    background:
      radial-gradient(circle at 16% 24%, rgba(242,181,192,0.22), transparent 32%),
      radial-gradient(circle at 86% 18%, rgba(201,168,76,0.18), transparent 38%);
  }

  .lc-eyebrow {
    margin: 0 0 14px;
    color: var(--lc-gold);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .lc-hero h1,
  .lc-section h2,
  .lc-story h2 {
    margin: 0;
    color: var(--lc-charcoal);
    font-family: "Cinzel", var(--font-heading--family, Georgia, serif);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: 0.03em;
  }

  .lc-hero h1 {
    max-width: 11ch;
    font-size: clamp(3.8rem, 8vw, 7.2rem);
  }

  .lc-hero__tagline {
    margin: 18px 0 0;
    color: var(--lc-gold);
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
  }

  .lc-hero__body,
  .lc-section__heading p,
  .lc-story p {
    color: var(--lc-gray);
    font-size: 1rem;
    line-height: 1.8;
  }

  .lc-hero__body {
    max-width: 560px;
    margin: 22px 0 0;
  }

  .lc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .lc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 28px;
    border: 1px solid var(--lc-gold);
    background: var(--lc-gold);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 180ms ease, color 180ms ease;
  }

  .lc-button:hover {
    background: var(--lc-gold-light);
    color: var(--lc-charcoal);
  }

  .lc-button--secondary {
    background: transparent;
    color: var(--lc-gold);
  }

  .lc-button--secondary:hover {
    background: var(--lc-gold);
    color: #fff;
  }

  .lc-proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
  }

  .lc-proof span {
    border-left: 1px solid rgba(201,168,76,0.38);
    padding-left: 12px;
    color: var(--lc-gray);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .lc-proof strong {
    display: block;
    color: var(--lc-gold);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lc-hero__visual {
    position: relative;
    aspect-ratio: 1;
    transform: perspective(1000px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 220ms ease-out;
  }

  .lc-hero__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 34px 42px rgba(201,168,76,0.16));
    animation: lc-breathe 7s ease-in-out infinite;
  }

  .lc-orbit {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--lc-gold);
    box-shadow: 0 0 18px rgba(201,168,76,0.62);
    animation: lc-drift 5.8s ease-in-out infinite;
  }

  .lc-orbit--one { left: 18%; top: 28%; }
  .lc-orbit--two { left: 78%; top: 22%; animation-delay: 700ms; }
  .lc-orbit--three { left: 84%; top: 70%; animation-delay: 1100ms; }

  .lc-marquee {
    overflow: hidden;
    background: var(--lc-charcoal);
    color: rgba(255,255,255,0.76);
  }

  .lc-marquee div {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    min-width: max-content;
    padding: 12px 0;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    animation: lc-marquee 34s linear infinite;
  }

  .lc-marquee b {
    color: var(--lc-gold);
    font-weight: 400;
  }

  .lc-section {
    max-width: 1240px;
    margin: 0 auto;
    padding: 76px 24px;
  }

  .lc-section--products {
    background: rgba(247,231,206,0.38);
    max-width: none;
  }

  .lc-section--products > * {
    max-width: 1240px;
    margin-inline: auto;
  }

  .lc-section__heading {
    margin-bottom: 34px;
  }

  .lc-section__heading--split {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  .lc-section__heading h2,
  .lc-story h2 {
    font-size: clamp(2.6rem, 5vw, 4.2rem);
  }

  .lc-section__heading a {
    color: var(--lc-gold);
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .lc-collection-grid,
  .lc-product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .lc-product-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .lc-collection-card,
  .lc-product-card {
    display: block;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.14);
    background: #fff;
    color: var(--lc-charcoal);
    text-decoration: none;
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .lc-collection-card:hover,
  .lc-product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201,168,76,0.42);
    box-shadow: 0 18px 44px rgba(201,168,76,0.16);
  }

  .lc-collection-card img,
  .lc-product-card img,
  .lc-product-card__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: #F9E8E0;
  }

  .lc-product-card__placeholder {
    display: grid;
    place-items: center;
    padding: 24px;
    color: var(--lc-gray);
    text-align: center;
  }

  .lc-collection-card span,
  .lc-product-card span {
    display: block;
    padding: 18px 18px 6px;
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.45rem;
  }

  .lc-collection-card small,
  .lc-product-card small {
    display: block;
    padding: 0 18px 20px;
    color: var(--lc-gray);
    line-height: 1.55;
  }

  .lc-product-card span {
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.95rem;
  }

  .lc-product-card small {
    color: var(--lc-gold);
    font-weight: 700;
  }

  .lc-empty-products {
    border: 1px dashed rgba(201,168,76,0.42);
    padding: 28px;
    color: var(--lc-gray);
    text-align: center;
  }

  .lc-story {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    align-items: center;
    gap: clamp(24px, 5vw, 76px);
    max-width: 1180px;
    margin: 0 auto;
    padding: 84px 24px;
  }

  .lc-story__image {
    --focus-x: 36%;
    --focus-y: 28%;
    --focus-origin: 34% 26%;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.18);
    background: var(--lc-champagne);
  }

  .lc-story__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.16);
    transform-origin: var(--focus-origin);
    transition: transform 420ms ease;
  }

  .lc-focus-ring {
    position: absolute;
    left: var(--focus-x);
    top: var(--focus-y);
    width: 88px;
    height: 88px;
    border: 1px solid rgba(201,168,76,0.86);
    border-radius: 999px;
    box-shadow: 0 0 32px rgba(201,168,76,0.45);
    transform: translate(-50%, -50%);
    transition: left 260ms ease, top 260ms ease;
  }

  .lc-focus-label {
    position: absolute;
    left: var(--focus-x);
    top: var(--focus-y);
    transform: translate(-50%, calc(-100% - 16px));
    border: 1px solid rgba(201,168,76,0.22);
    border-radius: 999px;
    background: rgba(255,255,255,0.92);
    color: var(--lc-gold);
    padding: 8px 16px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: left 260ms ease, top 260ms ease;
  }

  @keyframes lc-breathe {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  @keyframes lc-drift {
    0% { opacity: 0; transform: translateY(18px) scale(0.7); }
    35% { opacity: 0.88; }
    100% { opacity: 0; transform: translateY(-38px) scale(1.1); }
  }

  @keyframes lc-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media screen and (max-width: 900px) {
    .lc-hero,
    .lc-story {
      grid-template-columns: 1fr;
    }

    .lc-hero {
      padding-top: 44px;
    }

    .lc-hero h1 {
      font-size: clamp(3.2rem, 15vw, 5rem);
    }

    .lc-proof,
    .lc-collection-grid,
    .lc-product-grid {
      grid-template-columns: 1fr;
    }

    .lc-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lc-section__heading--split {
      align-items: start;
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luna Clara Homepage",
  "settings": [
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Jewelry"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore Gift Boxes"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Luna Clara Homepage"
    }
  ]
}
{% endschema %}
